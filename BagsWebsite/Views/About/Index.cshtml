@model BagsWebsite.Models.About

@{
    ViewData["Title"] = "About Us";
}

<style>
    .about-section {
        padding: 60px 0;
        background: #fff;
        font-family: 'Segoe UI', sans-serif;
    }

    .about-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 20px;
    }

    .about-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 50px;
        align-items: center;
    }

    /* Left Image */
    .about-image-box {
        position: relative;
    }

    .about-image {
        width: 100%;
        height: 400px;
        object-fit: cover;
        border-radius: 8px;
    }

    /* Right Content */
    .about-content {
        padding: 20px;
    }

    .about-subtitle {
        color: #666;
        font-size: 14px;
        margin-bottom: 10px;
        font-style: italic;
    }

    .about-heading {
        font-size: 28px;
        font-weight: 700;
        color: #333;
        margin-bottom: 20px;
        text-transform: uppercase;
    }

    .about-text {
        color: #666;
        font-size: 14px;
        line-height: 1.8;
        margin-bottom: 20px;
    }

    .about-line {
        width: 50px;
        height: 2px;
        background: #333;
        margin-bottom: 15px;
    }

    .about-years {
        font-size: 18px;
        color: #333;
        margin-bottom: 25px;
    }

    .about-btn {
        display: inline-block;
        background: #8b0000;
        color: #fff;
        padding: 12px 30px;
        border-radius: 4px;
        text-decoration: none;
        font-size: 13px;
        font-weight: 600;
        text-transform: uppercase;
        border: none;
        cursor: pointer;
    }

    .about-btn:hover {
        background: #6b0000;
    }

    /* Responsive */
    @@media (max-width: 768px) {
        .about-row {
            grid-template-columns: 1fr;
        }
    }
</style>

<section class="about-section">
    <div class="about-container">
        <div class="about-row">
            <!-- Left: Image -->
            <div class="about-image-box">
                <img src="@(Model?.ImageUrl ?? "~/uploads/products/about.jpg")" alt="About Us" class="about-image">
            </div>

            <!-- Right: Content -->
            <div class="about-content">
                <div class="about-subtitle">about us*****</div>
                <h1 class="about-heading">@(Model?.Heading ?? "WELCOME OUR ABOUT PAGE!")</h1>
                <p class="about-text">
                    @(Model?.Description ?? "Welcome to our bag store!")
                </p>
                <div class="about-line"></div>
                <div class="about-years">| 53 year of experience</div>
                <a href="/products" class="about-btn">ORDER IT NOW</a>
            </div>
        </div>
    </div>
</section>