  <script>
    // Page load pe 5 grid active karein
    document.addEventListener('DOMContentLoaded', function() {
        const btn5 = document.querySelector('.btn-grid-5');
        if(btn5) {
            changeView(btn5, 'grid-5');
        }
    });

    function changeView(btn, view) {
        const containers = document.querySelectorAll('.product-container');
        const wrappers = document.querySelectorAll('.product-wrapper');
        const width = window.innerWidth;

        containers.forEach((item, index) => {
            // 🔥 Bootstrap classes bhi add karo - yeh zaroori hai!
            item.className = 'product-container'; // Reset
            
            // View ke hisaab se classes add karo
            if(view === 'grid-6') {
                // 6 columns - Desktop: 2 per row (col-6), Mobile: 2 per row
                item.classList.add('col-6', 'col-md-4', 'col-lg-2');
            }
            else if(view === 'grid-5') {
                // 5 columns - Desktop: custom 20%, Mobile: 2 per row
                item.classList.add('col-6', 'col-md-4', 'col-lg-3', 'col-grid-5');
            }
            else if(view === 'grid-4') {
                // 4 columns - Desktop: 3 per row, Tablet: 4 per row, Mobile: 2 per row
                item.classList.add('col-6', 'col-md-4', 'col-lg-3');
            }
            else if(view === 'grid-3') {
                // 3 columns - Desktop: 4 per row, Tablet: 3 per row, Mobile: 2 per row
                item.classList.add('col-6', 'col-md-4');
            }
            else if(view === 'grid-2') {
                // 2 columns - Desktop: 6 per row, Mobile: 2 per row (col-6)
                item.classList.add('col-6', 'col-md-6');
            }
            else if(view === 'grid-1') {
                // 1 column - Full width
                item.classList.add('col-12');
                
                if(width <= 600) {
                    wrappers[index].classList.add('grid-1-active-mobile');
                } else {
                    wrappers[index].classList.add('grid-1-active-desktop');
                }
            }
        });

        // Update Active Button
        document.querySelectorAll('.view-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
    }

    // Window resize pe bhi check karein
    window.addEventListener('resize', function() {
        const activeBtn = document.querySelector('.view-btn.active');
        if(activeBtn) {
            const view = activeBtn.classList.contains('btn-grid-6') ? 'grid-6' :
                        activeBtn.classList.contains('btn-grid-5') ? 'grid-5' :
                        activeBtn.classList.contains('btn-grid-4') ? 'grid-4' :
                        activeBtn.classList.contains('btn-grid-3') ? 'grid-3' :
                        activeBtn.classList.contains('btn-grid-2') ? 'grid-2' : 'grid-1';
            changeView(activeBtn, view);
        }
    });
</script>
    <script>
        function changeColorDirect(element, newImageUrl) {
            // 1. Us specific card ka container dhoondein
            var wrapper = element.closest('.product-wrapper');

            // 2. Us card ki main aur hover images dhoondein
            var mainImg = wrapper.querySelector('.main-img');
            var hoverImg = wrapper.querySelector('.hover-img');

            if (mainImg) {
                // Smooth transition ke liye halki si opacity kam karein (Optional)
                mainImg.style.opacity = '0.5';

                // Nayi image set karein
                mainImg.src = newImageUrl;

                // Jab image load ho jaye toh wapis full opacity
                mainImg.onload = function() {
                    mainImg.style.opacity = '1';
                };
            }

            // Agar aap chahte hain ke hover karne par bhi wahi color dikhe
            if (hoverImg) {
                hoverImg.src = newImageUrl;
            }
        }
    </script>
    <script>
        function quickChangeImage(pId, newUrl) {
            // Image dhoondna ID ke zariye
            var targetImg = document.getElementById('cardImg-' + pId);

            if (targetImg) {
                // Animation reset
                targetImg.style.transition = 'none';
                targetImg.style.opacity = '0';
                targetImg.style.transform = 'translateX(-20px)';

                // Halka sa pause taake browser reset ko pakar sakay
                setTimeout(function() {
                    targetImg.src = newUrl;
                    targetImg.style.transition = 'all 0.4s ease-out';
                    targetImg.style.opacity = '1';
                    targetImg.style.transform = 'translateX(0)';
                }, 50);
            }
        }
    </script>
</body>
