@model List<BagsWebsite.Models.ProductReview>

@{
    ViewData["Title"] = "Customer Reviews";
    var avgRating = (double)(ViewBag.AverageRating ?? 0);
    var total = (int)(ViewBag.TotalReviews ?? 0);
}

<style>
    /* ===== REVIEWS PAGE STYLES ===== */
    .reviews-page {
        min-height: 100vh;
        padding: 40px 0;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    .container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 20px;
    }

    /* Header */
    .reviews-header {
        text-align: center;
        margin-bottom: 40px;
    }

        .reviews-header h1 {
            font-size: 42px;
            font-weight: 800;
            color: #2c3e50;
            margin-bottom: 10px;
        }

        .reviews-header p {
            color: #7f8c8d;
            font-size: 16px;
        }

    /* Stats Card */
    .stats-card {
        background: #fff;
        border-radius: 20px;
        padding: 40px;
        box-shadow: 0 20px 60px rgba(0,0,0,0.1);
        margin-bottom: 40px;
        display: grid;
        grid-template-columns: 1fr 2fr 1fr;
        gap: 40px;
        align-items: center;
    }

    .rating-big {
        text-align: center;
    }

    .rating-number {
        font-size: 72px;
        font-weight: 800;
        color: #2c3e50;
        line-height: 1;
    }

    .rating-stars {
        color: #f39c12;
        font-size: 24px;
        margin: 10px 0;
    }

    .rating-text {
        color: #7f8c8d;
        font-size: 14px;
    }

    /* Progress Bars */
    .rating-bars {
        padding: 0 20px;
    }

    .bar-item {
        display: flex;
        align-items: center;
        margin-bottom: 12px;
        font-size: 14px;
    }

    .bar-label {
        width: 60px;
        color: #555;
        font-weight: 500;
    }

    .bar-progress {
        flex: 1;
        height: 10px;
        background: #ecf0f1;
        border-radius: 5px;
        margin: 0 15px;
        overflow: hidden;
    }

    .bar-fill {
        height: 100%;
        border-radius: 5px;
        transition: width 0.5s ease;
    }

    .bar-count {
        width: 40px;
        text-align: right;
        color: #7f8c8d;
        font-weight: 600;
    }

    /* Write Review Button */
    .write-review-section {
        text-align: center;
    }

    .btn-write-review {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: #fff;
        border: none;
        padding: 15px 40px;
        border-radius: 50px;
        font-size: 16px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s;
        box-shadow: 0 10px 30px rgba(102, 126, 234, 0.4);
    }

        .btn-write-review:hover {
            transform: translateY(-3px);
            box-shadow: 0 15px 40px rgba(102, 126, 234, 0.5);
        }

    /* Reviews Grid */
    .reviews-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
        gap: 30px;
    }

    .review-card {
        background: #fff;
        border-radius: 20px;
        padding: 30px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.08);
        transition: all 0.3s;
        position: relative;
        overflow: hidden;
    }

        .review-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 20px 50px rgba(0,0,0,0.15);
        }

        .review-card::before {
            content: '"';
            position: absolute;
            top: -20px;
            right: 20px;
            font-size: 120px;
            color: #f39c12;
            opacity: 0.1;
            font-family: Georgia, serif;
        }

    .review-header-card {
        display: flex;
        align-items: center;
        margin-bottom: 20px;
    }

    .reviewer-avatar {
        width: 60px;
        height: 60px;
        border-radius: 50%;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-size: 20px;
        font-weight: 700;
        margin-right: 15px;
        position: relative;
    }

    .verified-badge {
        position: absolute;
        bottom: 0;
        right: 0;
        background: #27ae60;
        color: #fff;
        width: 20px;
        height: 20px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 10px;
        border: 2px solid #fff;
    }

    .reviewer-info h4 {
        font-size: 18px;
        font-weight: 700;
        color: #2c3e50;
        margin-bottom: 5px;
    }

    .review-stars-card {
        color: #f39c12;
        font-size: 14px;
    }

    .review-date {
        color: #95a5a6;
        font-size: 12px;
        margin-top: 3px;
    }

    .review-text {
        color: #555;
        font-size: 15px;
        line-height: 1.7;
        margin-bottom: 15px;
    }

    .review-image {
        width: 100%;
        max-width: 200px;
        border-radius: 10px;
        margin-top: 10px;
    }

    /* Modal */
    .modal-overlay {
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0,0,0,0.6);
        z-index: 9999;
        backdrop-filter: blur(5px);
    }

        .modal-overlay.show {
            display: flex;
            align-items: center;
            justify-content: center;
        }

    .modal-content {
        background: #fff;
        border-radius: 20px;
        width: 90%;
        max-width: 500px;
        max-height: 90vh;
        overflow-y: auto;
        animation: modalSlide 0.3s ease;
    }

    @@keyframes modalSlide {
        from {
            opacity: 0;
            transform: translateY(-50px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .modal-header {
        padding: 30px 30px 20px;
        border-bottom: 1px solid #ecf0f1;
    }

        .modal-header h3 {
            font-size: 24px;
            font-weight: 700;
            color: #2c3e50;
        }

    .modal-body {
        padding: 30px;
    }

    .close-btn {
        float: right;
        background: none;
        border: none;
        font-size: 28px;
        color: #95a5a6;
        cursor: pointer;
    }

    /* Star Input */
    .star-input {
        display: flex;
        flex-direction: row-reverse;
        justify-content: center;
        gap: 10px;
        font-size: 40px;
        margin-bottom: 25px;
    }

        .star-input input {
            display: none;
        }

        .star-input label {
            color: #ddd;
            cursor: pointer;
            transition: all 0.2s;
        }

            .star-input label:hover,
            .star-input label:hover ~ label,
            .star-input input:checked ~ label {
                color: #f39c12;
                transform: scale(1.2);
            }

    .form-group {
        margin-bottom: 20px;
    }

    .form-input {
        width: 100%;
        padding: 15px;
        border: 2px solid #ecf0f1;
        border-radius: 12px;
        font-size: 15px;
        transition: all 0.3s;
    }

        .form-input:focus {
            outline: none;
            border-color: #667eea;
        }

    .upload-area {
        border: 2px dashed #bdc3c7;
        border-radius: 12px;
        padding: 30px;
        text-align: center;
        cursor: pointer;
        transition: all 0.3s;
    }

        .upload-area:hover {
            border-color: #667eea;
            background: #f8f9ff;
        }

    .submit-btn {
        width: 100%;
        padding: 16px;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: #fff;
        border: none;
        border-radius: 12px;
        font-size: 16px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s;
    }

        .submit-btn:disabled {
            background: #bdc3c7;
            cursor: not-allowed;
        }

        .submit-btn:hover:not(:disabled) {
            transform: translateY(-2px);
            box-shadow: 0 10px 30px rgba(102, 126, 234, 0.4);
        }

    /* Empty State */
    .empty-reviews {
        text-align: center;
        padding: 80px 20px;
    }

        .empty-reviews i {
            font-size: 80px;
            color: #bdc3c7;
            margin-bottom: 20px;
        }

        .empty-reviews h3 {
            color: #7f8c8d;
            font-size: 24px;
        }

    @@media (max-width: 768px) {
        .stats-card {
            grid-template-columns: 1fr;
            gap: 30px;
        }

        .reviews-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="reviews-page">
    <div class="container">
        <!-- Header -->
        <div class="reviews-header">
            <h1 style="color:brown"> Reviews</h1s>
            <p>See what our customers say about us</p>
        </div>

        <!-- Stats Card -->
        <div class="stats-card">
            <!-- Left: Big Rating -->
            <div class="rating-big">
                <div class="rating-number">@avgRating.ToString("0.0")</div>
                <div class="rating-stars">
                    @for (int i = 1; i <= 5; i++)
                    {
                        if (i <= Math.Round(avgRating))
                        {
                            <i class="fa fa-star"></i>
                        }
                        else
                        {
                            <i class="fa fa-star-o"></i>
                        }
                    }
                </div>
                <div class="rating-text">@total Reviews</div>
            </div>

            <!-- Middle: Progress Bars -->
            <div class="rating-bars">
                @{
                    var ratings = new[] {
                                new { Star = 5, Count = (int)ViewBag.FiveStar },
                                new { Star = 4, Count = (int)ViewBag.FourStar },
                                new { Star = 3, Count = (int)ViewBag.ThreeStar },
                                new { Star = 2, Count = (int)ViewBag.TwoStar },
                                new { Star = 1, Count = (int)ViewBag.OneStar }
                                };
                }
                @foreach (var r in ratings)
                {
                    var percent = total > 0 ? (r.Count * 100 / total) : 0;
                    <div class="bar-item">
                        <span class="bar-label">@r.Star Star</span>
                        <div class="bar-progress">
                            <div class="bar-fill" style="width: @percent%; background: @(r.Star >= 4 ? "#f39c12" : "#bdc3c7")"></div>
                        </div>
                        <span class="bar-count">@r.Count</span>
                    </div>
                }
            </div>

            <!-- Right: Write Review -->
            <div class="write-review-section">
                <button class="btn-write-review" onclick="openModal()" style="background:brown">
                    <i class="fa fa-pen me-2"></i>Write a Review
                </button>
            </div>
        </div>

        <!-- Reviews Grid -->
        @if (Model != null && Model.Any())
        {
            <div class="reviews-grid">
                @foreach (var review in Model)
                {
                    var initials = string.Join("", review.CustomerName.Split(' ').Take(2).Select(n => n[0]));

                    <div class="review-card">
                        <div class="review-header-card">
                            <div class="reviewer-avatar">
                                @initials
                                <span class="verified-badge"><i class="fa fa-check"></i></span>
                            </div>
                            <div class="reviewer-info">
                                <h4>@review.CustomerName</h4>
                                <div class="review-stars-card">
                                    @for (int i = 0; i < review.Rating; i++)
                                    {
                                        <i class="fa fa-star"></i>
                                    }
                                </div>
                                <div class="review-date">@review.CreatedAt?.ToString("MMM dd, yyyy")</div>
                            </div>
                        </div>
                        <p class="review-text">@review.Message</p>
                        @if (!string.IsNullOrEmpty(review.ImageUrl))
                        {
                            <img src="@review.ImageUrl" class="review-image" alt="Review Image">
                        }
                    </div>
                }
            </div>
        }
        else
        {
            <div class="empty-reviews">
                <i class="fa fa-comments-o"></i>
                <h3>No reviews yet. Be the first to review!</h3>
            </div>
        }
    </div>
</div>

<!-- Write Review Modal -->
<div id="reviewModal" class="modal-overlay">
    <div class="modal-content">
        <div class="modal-header">
            <h3>Write a Review</h3>
            <button class="close-btn" onclick="closeModal()">&times;</button>
        </div>
        <div class="modal-body">
            <form id="reviewForm" enctype="multipart/form-data">
                <!-- Star Rating -->
                <div class="star-input">
                    <input type="radio" name="Rating" value="5" id="star5" required>
                    <label for="star5"><i class="fa fa-star"></i></label>
                    <input type="radio" name="Rating" value="4" id="star4">
                    <label for="star4"><i class="fa fa-star"></i></label>
                    <input type="radio" name="Rating" value="3" id="star3">
                    <label for="star3"><i class="fa fa-star"></i></label>
                    <input type="radio" name="Rating" value="2" id="star2">
                    <label for="star2"><i class="fa fa-star"></i></label>
                    <input type="radio" name="Rating" value="1" id="star1">
                    <label for="star1"><i class="fa fa-star"></i></label>
                </div>

                <div class="form-group">
                    <input type="text" name="CustomerName" class="form-input" placeholder="Your Name" required>
                </div>

                <div class="form-group">
                    <input type="email" name="Email" class="form-input" placeholder="Your Email" required>
                </div>

                <div class="form-group">
                    <textarea name="Message" class="form-input" rows="4" placeholder="Write your review..." required></textarea>
                </div>

                <div class="form-group">
                    <div class="upload-area" onclick="document.getElementById('revImage').click()">
                        <i class="fa fa-camera fa-2x" style="color: #bdc3c7;"></i>
                        <p style="color: #7f8c8d; margin-top: 10px;">Click to upload photo (optional)</p>
                        <img id="imgPreview" style="max-width: 100px; display: none; margin-top: 10px; border-radius: 8px;">
                    </div>
                    <input type="file" name="imageFile" id="revImage" accept="image/*" style="display: none;" onchange="previewImage(this)">
                </div>

                <button type="submit" id="submitBtn" class="submit-btn" disabled>Submit Review</button>
            </form>
        </div>
    </div>
</div>

<script>
    function openModal() {
        document.getElementById('reviewModal').classList.add('show');
        document.body.style.overflow = 'hidden';
    }

    function closeModal() {
        document.getElementById('reviewModal').classList.remove('show');
        document.body.style.overflow = '';
        resetForm();
    }

    function resetForm() {
        document.getElementById('reviewForm').reset();
        document.getElementById('imgPreview').style.display = 'none';
        document.getElementById('submitBtn').disabled = true;
    }

    function previewImage(input) {
        if (input.files && input.files[0]) {
            var reader = new FileReader();
            reader.onload = function(e) {
                document.getElementById('imgPreview').src = e.target.result;
                document.getElementById('imgPreview').style.display = 'block';
            }
            reader.readAsDataURL(input.files[0]);
        }
    }

    // Form validation
    const form = document.getElementById('reviewForm');
    const submitBtn = document.getElementById('submitBtn');

    form.addEventListener('input', function() {
        const rating = document.querySelector('input[name="Rating"]:checked');
        const name = form.querySelector('[name="CustomerName"]').value.trim();
        const email = form.querySelector('[name="Email"]').value.trim();
        const message = form.querySelector('[name="Message"]').value.trim();
        const emailValid = /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/.test(email);

        submitBtn.disabled = !(rating && name && emailValid && message.length >= 5);
    });

    // Submit
    form.addEventListener('submit', function(e) {
        e.preventDefault();
        submitBtn.innerHTML = '<i class="fa fa-spinner fa-spin"></i> Submitting...';

        fetch('/Reviews/Create', {
            method: 'POST',
            body: new FormData(this)
        })
        .then(r => r.json())
        .then(data => {
            alert(data.message);
            if (data.success) {
                closeModal();
                location.reload();
            } else {
                submitBtn.innerHTML = 'Submit Review';
            }
        });
    });

    // Close on escape
    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') closeModal();
    });
</script>