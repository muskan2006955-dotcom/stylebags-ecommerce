<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Galaxy</title>

    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;600;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

    <style>
        :root {
            --primary-teal: #005555;
            --dark-teal: #004444;
            --deep-teal: #003333;
            --accent-green: #10a37f;
            --bg-gray: #f3f4f6;
            --sidebar-width: 260px;
        }

        body {
            background-color: var(--bg-gray);
            font-family: 'Plus Jakarta Sans', sans-serif;
            margin: 0;
            overflow-x: hidden;
        }

        /* --- Sidebar Style --- */
        .sidebar {
            height: 100vh;
            background-color: var(--primary-teal);
            color: white;
            position: fixed;
            width: var(--sidebar-width);
            display: flex;
            flex-direction: column;
            overflow-y: auto;
            z-index: 1000;
            box-shadow: 2px 0 10px rgba(0,0,0,0.1);
            transition: all 0.3s ease;
        }

        .sidebar-brand {
            padding: 25px 20px;
            font-size: 1.2rem;
            font-weight: 800;
            background: var(--dark-teal);
            text-align: center;
            border-bottom: 1px solid rgba(255,255,255,0.1);
            letter-spacing: 1.5px;
            text-transform: uppercase;
            position: sticky;
            top: 0;
            z-index: 10;
        }

        /* Nav Links */
        .nav-link-custom {
            color: rgba(255, 255, 255, 0.85);
            text-decoration: none !important;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 14px 20px;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            border-left: 4px solid transparent;
        }

            .nav-link-custom:hover {
                color: white;
                background: rgba(255, 255, 255, 0.1);
            }

        .active-page {
            background-color: var(--deep-teal) !important;
            color: white !important;
            font-weight: 700;
            border-left: 4px solid var(--accent-green) !important;
        }

        /* Submenu - Default Open */
        .submenu {
            display: block; /* Links khulay rahen ge */
            background: rgba(0, 0, 0, 0.1);
            padding-bottom: 8px;
        }

            .submenu a {
                padding: 10px 25px 10px 45px;
                font-size: 13px;
                color: rgba(255, 255, 255, 0.7);
                display: block;
                text-decoration: none !important;
                transition: 0.2s;
            }

                .submenu a:hover {
                    color: white;
                    background: rgba(255,255,255,0.05);
                    padding-left: 50px;
                }

        /* --- Content Area --- */
        .content {
            margin-left: var(--sidebar-width);
            min-height: 100vh;
        }

        .topbar {
            background-color: #ffffff;
            padding: 12px 25px;
            border-bottom: 1px solid #e5e7eb;
            display: flex;
            justify-content: space-between;
            align-items: center;
            position: sticky;
            top: 0;
            z-index: 100;
        }

        /* Buttons Style */
        .galaxy-ai-btn {
            display: inline-flex;
            align-items: center;
            padding: 8px 16px;
            background: #ffffff;
            border: 1px solid var(--primary-teal);
            border-radius: 12px;
            color: var(--primary-teal) !important;
            text-decoration: none !important;
            font-weight: 600;
            font-size: 14px;
            transition: all 0.3s ease;
        }

            .galaxy-ai-btn:hover {
                background: var(--primary-teal);
                color: #fff !important;
                transform: translateY(-2px);
            }

        .logout-btn-header {
            background: #fff5f5;
            color: #ef4444;
            padding: 8px 18px;
            border-radius: 8px;
            text-decoration: none !important;
            font-size: 13px;
            font-weight: 700;
            border: 1px solid #fee2e2;
        }

            .logout-btn-header:hover {
                background: #ef4444;
                color: white;
            }

        /* Icon Rotation Logic */
        .fa-chevron-down {
            transition: transform 0.3s ease;
            font-size: 10px;
        }

        .rotate-icon {
            transform: rotate(-180deg);
        }

        /* Scrollbar */
        .sidebar::-webkit-scrollbar {
            width: 5px;
        }

        .sidebar::-webkit-scrollbar-track {
            background: var(--primary-teal);
        }

        .sidebar::-webkit-scrollbar-thumb {
            background: rgba(255,255,255,0.2);
            border-radius: 10px;
        }
    </style>
</head>
<body>

    <div class="sidebar">
        <div class="sidebar-brand">GALAXY ADMIN</div>

        <a class="nav-link-custom" asp-controller="AdminDashboard"  asp-action="Index">
            <span><i class="fa fa-th-large me-2"></i> Dashboard</span>
        </a>

        <div class="menu-item">
            <div class="nav-link-custom toggle-btn">
                <span><i class="fa fa-box me-2"></i>Products</span>
                <i class="fa fa-chevron-down rotate-icon"></i>
            </div>
            <div class="submenu">
                <a asp-controller="Products" asp-action="Create">Add Products</a>
                <a asp-controller="Products" asp-action="Index">Manage Products</a>
            </div>
        </div>

        <div class="menu-item">
            <div class="nav-link-custom toggle-btn">
                <span><i class="fa fa-bus me-2"></i>Categories</span>
                <i class="fa fa-chevron-down rotate-icon"></i>
            </div>
            <div class="submenu">
                <a asp-controller="Categories" asp-action="Create">Add Categories</a>
                <a asp-controller="Categories" asp-action="Index">Categories</a>

            </div>
        </div>
        <div class="menu-item">
            <div class="nav-link-custom toggle-btn">
                <span><i class="fa fa-bus me-2"></i>OrderDetails</span>
                <i class="fa fa-chevron-down rotate-icon"></i>
            </div>
            <div class="submenu">
                <a asp-controller="Orders" asp-action="Index">Orders</a>

            </div>
        </div>

        <div class="menu-item">
            <div class="nav-link-custom toggle-btn">
                <span><i class="fa fa-shield-halved me-2"></i> System Policies</span>
                <i class="fa fa-chevron-down rotate-icon"></i>
            </div>
            <div class="submenu">
                <a asp-controller="SystemLog" asp-action="Index">SystemLog</a>
            </div>
        </div>

    </div>

    <div class="content">
        <div class="topbar shadow-sm">
            <h5 class="m-0 fw-bold text-dark">@ViewData["Title"]</h5>

            <div class="d-flex align-items-center gap-3">
                <span class="text-muted small d-none d-md-inline">
                    <i class="fa fa-user-shield me-1 text-primary"></i>
                    Admin: <b>@Context.Session.GetString("UserName")</b>
                </span>

                <a asp-controller="ChatBot" asp-action="Index" class="galaxy-ai-btn">
                    <i class="fas fa-robot me-2"></i> Galaxy AI
                </a>

                <a asp-controller="Account" asp-action="Logout" asp-area="Home" class="logout-btn-header">
                    <i class="fa fa-power-off"></i> Logout
                </a>
            </div>
        </div>

        <div class="p-4">
            @RenderBody()
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        $(document).ready(function () {
            // Toggle Logic: Click karne par band ya khulna
            $('.toggle-btn').click(function () {
                var submenu = $(this).next('.submenu');
                submenu.slideToggle(300);
                $(this).find('.fa-chevron-down').toggleClass('rotate-icon');
            });

            // Active Link Highlighting
            var currentPath = window.location.pathname;
            $('.sidebar a').each(function () {
                var href = $(this).attr('href');
                if (currentPath === href) {
                    $(this).addClass('active-page');
                    // Agar link kisi submenu ke andar hai, toh use open hi rehne dein
                    $(this).closest('.submenu').show();
                }
            });
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>