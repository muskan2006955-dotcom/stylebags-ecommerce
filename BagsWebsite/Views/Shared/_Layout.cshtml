<script>
    // 1. Wishlist Logic (Global)
    function addToWishlist(productId, btn) {
        let pId = productId.toString().trim();
        let wishlist = JSON.parse(localStorage.getItem('guestWishlist')) || [];
        let index = wishlist.indexOf(pId);

        if (index === -1) {
            wishlist.push(pId);
            console.log("Added to Wishlist:", pId);
        } else {
            wishlist.splice(index, 1);
            console.log("Removed from Wishlist:", pId);
        }

        localStorage.setItem('guestWishlist', JSON.stringify(wishlist));

        // Aik hi waqt mein pure page ke hearts ko update karein
        renderHearts();
    }

    // 2. UI Rendering Logic (Hamesha isi se UI update hogi)
    function renderHearts() {
        let wishlist = JSON.parse(localStorage.getItem('guestWishlist')) || [];

        // Saare elements dhondein jin ke paas data-product-id hai
        let allHearts = document.querySelectorAll('[data-product-id]');

        allHearts.forEach(el => {
            let currentId = el.getAttribute('data-product-id').toString().trim();
            let icon = el.querySelector('i');

            if (wishlist.includes(currentId)) {
                // Agar wishlist mein hai toh RED Solid karein
                if(icon) icon.className = 'fa-solid fa-heart text-danger';
                el.classList.add('is-active');
            } else {
                // Agar nahi hai toh Regular Gray karein
                if(icon) icon.className = 'fa-regular fa-heart';
                el.classList.remove('is-active', 'text-danger');
            }
        });
    }

    // 3. Auto-Execution on Every Page Event
    $(document).ready(function() {
        // 1. Refresh par
        setTimeout(renderHearts, 500);

        // 2. Jab Quick View Modal khule
        $(document).on('shown.bs.modal', function () {
            renderHearts();
        });
    });

    // 3. Jab user 'Back' button se aaye
    window.addEventListener('pageshow', function() {
        renderHearts();
    });

    // 4. Double check for safety
    window.onload = renderHearts;
</script>
<script>
        // Isay Layout ki script ke bilkul end mein paste karein
    $(document).ready(function() {
        syncWishlistToDatabase();
    });

      function syncWishlistToDatabase() {
        var userId = '@Context.Session.GetString("UserId")';
        if (userId !== "") {
            let guestWishlist = JSON.parse(localStorage.getItem("guestWishlist")) || [];

            // IDs ko numbers mein convert karlein taake Controller ko asani ho
            let numericIds = guestWishlist.map(id => parseInt(id)).filter(id => !isNaN(id));

            if (numericIds.length > 0) {
                console.log("Attempting to sync:", numericIds);

                fetch('/Wishlist/SyncWishlist', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(numericIds)
                })
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        console.log("Success! Database updated.");
                        localStorage.removeItem("guestWishlist"); // Sirf success par delete karein
                        renderHearts(); // Hearts update karein
                    } else {
                        console.error("Server Error:", data.message);
                    }
                })
                .catch(err => console.error("Network Error:", err));
            }
        }
    }
</script>
<script>
    // Open Search Function
    function openSearch() {
        console.log('Opening search...');

        // Close offcanvas first (agar open ho)
        var offcanvas = document.querySelector('.offcanvas-menu-wrapper');
        if (offcanvas && offcanvas.classList.contains('active')) {
            offcanvas.classList.remove('active');
        }

        // Open search modal
        var modal = document.getElementById('searchModal');
        if (modal) {
            modal.classList.add('active');
            modal.style.display = 'flex';
            document.getElementById('searchInput').focus();
        }
    }

    // Close Search Function
    function closeSearch() {
        var modal = document.getElementById('searchModal');
        if (modal) {
            modal.classList.remove('active');
            modal.style.display = 'none';
        }
        document.getElementById('searchInput').value = '';
        document.getElementById('searchResults').innerHTML = '';
    }

    // Live Search
    var searchTimeout;
    var searchInput = document.getElementById('searchInput');
    var resultsDiv = document.getElementById('searchResults');

    if (searchInput) {
        searchInput.addEventListener('input', function() {
            clearTimeout(searchTimeout);
            var query = this.value.trim();

            if (query.length < 2) {
                resultsDiv.innerHTML = '';
                return;
            }

            resultsDiv.innerHTML = '<div style="padding:20px;text-align:center;"><i class="fa fa-spinner fa-spin"></i> Searching...</div>';

            searchTimeout = setTimeout(function() {
                fetch('/Home/Search?term=' + encodeURIComponent(query))
                    .then(function(response) {
                        if (!response.ok) throw new Error('HTTP ' + response.status);
                        return response.json();
                    })
                    .then(function(data) {
                        displayResults(data, query);
                    })
                    .catch(function(err) {
                        console.error('Search error:', err);
                        resultsDiv.innerHTML = '<div class="no-results">Search failed. Please try again.</div>';
                    });
            }, 300);
        });
    }

    // Display Results
    function displayResults(data, query) {
        if (!data || data.length === 0) {
            resultsDiv.innerHTML = '<div class="no-results"><i class="fa fa-search" style="font-size:40px;display:block;margin-bottom:15px;"></i>No results for "' + escapeHtml(query) + '"</div>';
            return;
        }

        var categories = data.filter(function(x) { return x.type === 'category'; });
        var products = data.filter(function(x) { return x.type === 'product'; });

        var html = '';

        // Categories
        if (categories.length > 0) {
            html += '<div class="result-section">Categories</div>';
            categories.forEach(function(c) {
                html += '<a href="' + c.url + '" class="result-item">';
                html += '<div class="result-info" style="flex:1;">';
                html += '<h4>' + highlight(c.name, query) + '</h4>';
                html += '<p>' + c.productCount + ' products</p>';
                html += '</div>';
                html += '<span style="background:#667eea;color:white;padding:3px 10px;border-radius:15px;font-size:11px;">Category</span>';
                html += '</a>';
            });
        }

        // Products
        if (products.length > 0) {
            html += '<div class="result-section">Products</div>';
            products.forEach(function(p) {
                var priceHtml = p.discount > 0
                    ? '<span style="text-decoration:line-through;color:#999;font-size:12px;">$' + p.price + '</span> $' + p.finalPrice.toFixed(0)
                    : '$' + p.price;

                html += '<a href="' + p.url + '" class="result-item">';
                html += '<img src="' + (p.image || '/uploads/products/no-image.jpg') + '" onerror="this.src=\'/uploads/products/no-image.jpg\'">';
                html += '<div class="result-info">';
                html += '<h4>' + highlight(p.name, query) + '</h4>';
                html += '<p>' + p.category + '</p>';
                html += '</div>';
                html += '<div class="result-price">' + priceHtml + '</div>';
                html += '</a>';
            });
        }

        // View All
        html += '<a href="/Home/SearchResults?term=' + encodeURIComponent(query) + '" class="view-all">View All Results <i class="fa fa-arrow-right"></i></a>';

        resultsDiv.innerHTML = html;
    }

    // Helpers
    function highlight(text, query) {
        var regex = new RegExp('(' + escapeHtml(query) + ')', 'gi');
        return text.replace(regex, '<mark style="background:#ffe4e9;padding:0 2px;">$1</mark>');
    }

    function escapeHtml(text) {
        var div = document.createElement('div');
        div.textContent = text;
        return div.innerHTML;
    }

    // Close on Escape
    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') closeSearch();
    });
</script>
