    <!-- CART SCRIPT - LAST MEIN -->
    <!-- ========================================== -->
    <script>
        $(document).ready(function() {
            console.log('🛒 Cart Initializing...');

            // Check if user is logged in
            var userId = '@Context.Session.GetString("UserId")';
            console.log('User ID:', userId);

            if (!userId) {
                console.log('User not logged in');
                $('#cartSidebarContent').html(
                    '<div class="text-center py-5">' +
                    '<i class="fa fa-lock fa-3x text-muted mb-3"></i>' +
                    '<p>Please login to view cart</p>' +
                    '<a href="/Account/Login" class="btn btn-dark btn-sm">Login</a>' +
                    '</div>'
                );
                return;
            }

            // Load cart on page load
            loadCartSummary();
        });

        // Load Cart Summary (Badge)
        function loadCartSummary() {
            $.ajax({
                url: '/Cart/GetCartSummary',
                type: 'GET',
                cache: false,
                success: function(data) {
                    console.log('Cart Summary:', data);
                    updateCartBadge(data.count);

                    if (data.count > 0) {
                        loadCartItems();
                    } else {
                        showEmptyCart();
                    }
                },
                error: function(xhr) {
                    console.error('Error loading summary:', xhr.status, xhr.responseText);
                    $('#cartSidebarContent').html(
                        '<div class="text-center py-5 text-danger">' +
                        '<p>Error loading cart (' + xhr.status + ')</p>' +
                        '</div>'
                    );
                }
            });
        }

        // Load Cart Items
        function loadCartItems() {
            $.ajax({
                url: '/Cart/GetCartItems',
                type: 'GET',
                cache: false,
                success: function(data) {
                    console.log('Cart Items:', data);

                    if (data.success && data.items && data.items.length > 0) {
                        renderCartItems(data);
                    } else {
                        showEmptyCart();
                    }
                },
                error: function(xhr) {
                    console.error('Error loading items:', xhr.status);
                    $('#cartSidebarContent').html(
                        '<div class="text-center py-5 text-danger">' +
                        '<p>Failed to load items</p>' +
                        '</div>'
                    );
                }
            });
        }

        // Render Cart Items
        function renderCartItems(data) {
            var html = '';

            for (var i = 0; i < data.items.length; i++) {
                var item = data.items[i];
                var price = parseFloat(item.price) || 0;

                html += '<div class="cart-item" style="display:flex;padding:15px;border-bottom:1px solid #ebebeb;gap:15px;align-items:center;">' +
                    '<img src="' + (item.imageUrl || '/img/no-image.jpg') + '" style="width:70px;height:70px;object-fit:cover;border-radius:8px;" onerror="this.src=\'/img/no-image.jpg\'">' +
                    '<div style="flex:1;">' +
                    '<div style="font-weight:600;font-size:14px;margin-bottom:5px;">' + item.productName + '</div>' +
                    '<div style="color:#c0392b;font-weight:700;font-size:14px;margin-bottom:8px;">Rs. ' + price.toLocaleString() + '</div>' +
                    '<div style="display:flex;align-items:center;gap:10px;">' +
                    '<div style="display:flex;align-items:center;border:1px solid #ddd;border-radius:20px;overflow:hidden;height:28px;">' +
                    '<button onclick="updateQuantity(' + item.cartItemId + ', ' + (item.quantity - 1) + ')" style="background:none;border:none;width:28px;cursor:pointer;">−</button>' +
                    '<input type="text" value="' + item.quantity + '" readonly style="width:35px;text-align:center;border:none;font-size:13px;font-weight:600;">' +
                    '<button onclick="updateQuantity(' + item.cartItemId + ', ' + (item.quantity + 1) + ')" style="background:none;border:none;width:28px;cursor:pointer;">+</button>' +
                    '</div>' +
                    '<span onclick="removeItem(' + item.cartItemId + ')" style="color:#999;cursor:pointer;font-size:16px;margin-left:auto;width:28px;height:28px;display:flex;align-items:center;justify-content:center;border-radius:50%;">' +
                    '<i class="fa fa-trash"></i>' +
                    '</span>' +
                    '</div>' +
                    '</div>' +
                    '</div>';
            }

            $('#cartSidebarContent').html(html);
            $('#cartSidebarFooter').show();
            $('#cartTotalPrice').text('Rs. ' + (parseFloat(data.total) || 0).toLocaleString());
        }

        // Show Empty Cart
        function showEmptyCart() {
            $('#cartSidebarContent').html(
                '<div class="text-center py-5">' +
                '<i class="fa fa-shopping-bag fa-3x text-muted mb-3"></i>' +
                '<p>Your cart is empty</p>' +
                '<button class="btn btn-dark btn-sm" onclick="closeCartSidebar()">Continue Shopping</button>' +
                '</div>'
            );
            $('#cartSidebarFooter').hide();
        }

        // Update Quantity
        function updateQuantity(cartItemId, newQty) {
            if (newQty < 1) {
                if (!confirm('Remove this item?')) return;
            }

            $.post('/Cart/UpdateQuantity', { cartItemId: cartItemId, quantity: newQty }, function(data) {
                if (data.success) {
                    updateCartBadge(data.itemCount);
                    if (data.itemCount > 0) {
                        loadCartItems();
                    } else {
                        showEmptyCart();
                    }
                }
            });
        }

        // Remove Item
        function removeItem(cartItemId) {
            if (!confirm('Remove this item?')) return;

            $.post('/Cart/RemoveItem', { cartItemId: cartItemId }, function(data) {
                if (data.success) {
                    updateCartBadge(data.itemCount);
                    if (data.itemCount > 0) {
                        loadCartItems();
                    } else {
                        showEmptyCart();
                    }
                }
            });
        }

        // Update Badge
        function updateCartBadge(count) {
            // Header badge
            var $headerBadge = $('.header__right__widget .icon_bag_alt').siblings('.tip');
            if ($headerBadge.length === 0) {
                $('.header__right__widget .icon_bag_alt').after('<div class="tip">0</div>');
                $headerBadge = $('.header__right__widget .icon_bag_alt').siblings('.tip');
            }

            // Offcanvas badge
            var $offcanvasBadge = $('.offcanvas__widget .icon_bag_alt').siblings('.tip');
            if ($offcanvasBadge.length === 0) {
                $('.offcanvas__widget .icon_bag_alt').after('<div class="tip">0</div>');
                $offcanvasBadge = $('.offcanvas__widget .icon_bag_alt').siblings('.tip');
            }

            // Update both
            $headerBadge.text(count || 0).toggle(count > 0);
            $offcanvasBadge.text(count || 0).toggle(count > 0);

            // Style
            $('.tip').css({
                'position': 'absolute',
                'top': '-8px',
                'right': '-8px',
                'background': 'linear-gradient(135deg, #c0392b 0%, #8b4513 100%)',
                'color': 'white',
                'font-size': '11px',
                'font-weight': 'bold',
                'min-width': '20px',
                'height': '20px',
                'border-radius': '50%',
                'display': count > 0 ? 'flex' : 'none',
                'align-items': 'center',
                'justify-content': 'center'
            });
        }

        // Open Sidebar
        function openCartSidebar() {
            console.log('Opening sidebar...');
            $('.cart-sidebar-overlay').addClass('active');
            $('#cartSidebarWrapper').addClass('active');
            $('body').css('overflow', 'hidden');

            // Reload items when opening
            var userId = '@Context.Session.GetString("UserId")';
            if (userId) {
                loadCartItems();
            }
        }

        // Close Sidebar
        function closeCartSidebar() {
            $('.cart-sidebar-overlay').removeClass('active');
            $('#cartSidebarWrapper').removeClass('active');
            $('body').css('overflow', '');
        }

        // Add to Cart
        function addToCart(productId, qty) {
            if (!qty) qty = 1;

            $.post('/Cart/AddToCart', { productId: productId, quantity: qty }, function(data) {
                if (data.success) {
                    updateCartBadge(data.count);
                    openCartSidebar();
                } else if (data.redirectUrl) {
                    window.location.href = data.redirectUrl;
                } else {
                    alert(data.message);
                }
            });
        }

        // Event Bindings
        $(document).on('click', '.icon_bag_alt', function(e) {
            e.preventDefault();
            openCartSidebar();
        });

        $(document).on('keydown', function(e) {
            if (e.key === 'Escape') closeCartSidebar();
        });
    </script>
</body>
