@model BagsWebsite.Models.ViewModels.ResetPasswordViewModel

<div class="login-wrapper">
    <div class="login-card">
        <h3 class="login-title">Create New Password</h3>
        <p class="text-center text-muted small">Resetting password for: <b>@Model.Email</b></p>

        <div class="login-body">
            <form asp-action="ResetPassword" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Email" />

                <div class="mb-3">
                    <label class="small fw-bold">New Password</label>
                    <input asp-for="NewPassword" class="form-control-custom" placeholder="••••••••" />
                    <span asp-validation-for="NewPassword" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label class="small fw-bold">Confirm Password</label>
                    <input asp-for="ConfirmPassword" class="form-control-custom" placeholder="••••••••" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn-login">Reset Password</button>
            </form>
        </div>
    </div>
</div>