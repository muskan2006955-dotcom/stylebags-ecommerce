@model BagsWebsite.Models.User
@{
    ViewData["Title"] = "Login";
}

@* Google Font: Poppins or Inter for that clean look *@
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">

<style>
    /* Resetting default body margin to center properly */
    body {
        background-color: var(--bg-soft);
        font-family: 'Poppins', sans-serif;
        margin: 0;
        padding: 0;
    }

    /* Outer wrapper to center the card */
    .login-wrapper {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 20px;
    }

    /* The main white card from the image */
    .login-card {
        width: 100%;
        max-width: 400px;
        background-color: #ffffff;
        border-radius: 12px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
        padding: 30px;
        border: 1px solid #e1e1e1;
    }

    /* The Shopping Girl Image section */
    .login-image-section {
        text-align: center;
        margin-bottom: 25px;
    }

        .login-image-section img {
            width: 100%;
            max-width: 300px; /* Adjusting size to look neat */
            height: auto;
            border-radius: 10px;
        }

    /* Heading: Login to Your Account */
    .login-title {
        font-size: 20px;
        font-weight: 600;
        color: #333333;
        margin-bottom: 20px;
        text-align: center;
    }

    /* Custom Input Fields */
    .form-control-custom {
        width: 100%;
        padding: 12px 16px;
        margin-bottom: 15px;
        border: 1px solid #ddd;
        border-radius: 8px;
        font-size: 14px;
        transition: all 0.3s ease;
        box-sizing: border-box; /* Crucial for padding to not expand width */
    }

        .form-control-custom:focus {
            border-color: #000;
            box-shadow: 0 0 0 3px rgba(0,0,0,0.05);
            outline: none;
        }

    /* Checkbox & Text: I agree to the... */
    .login-agreement {
        display: flex;
        align-items: center;
        font-size: 13px;
        color: #666;
        margin-bottom: 20px;
    }

        .login-agreement input[type="checkbox"] {
            margin-right: 10px;
            cursor: pointer;
        }

        .login-agreement a {
            color: #000; /* Black links as per common modern themes */
            text-decoration: none;
            font-weight: 500;
        }

            .login-agreement a:hover {
                text-decoration: underline;
            }

    /* The Black Login Button */
    .btn-login {
        width: 100%;
        padding: 14px;
        background-color: #000000;
        color: #ffffff;
        border: none;
        border-radius: 8px;
        font-weight: 600;
        font-size: 15px;
        text-transform: uppercase;
        letter-spacing: 1px;
        cursor: pointer;
        transition: background-color 0.3s;
        margin-bottom: 20px;
    }

        .btn-login:hover {
            background-color: #333333;
        }

    /* Footer links: Forgot & Create Account */
    .login-footer {
        text-align: center;
        font-size: 13px;
        color: #666;
    }

        .login-footer a {
            color: #000;
            text-decoration: none;
            font-weight: 600;
            margin: 0 5px;
        }

            .login-footer a:hover {
                text-decoration: underline;
            }

    /* Specific spacing for separate link lines */
    .login-footer-links {
        margin-top: 10px;
    }
</style>

<div class="login-wrapper">
    <div class="login-card">
        <div class="login-image-section">
            @* Place the exact image here. For placeholder, using an online URL *@
            <img src="~/uploads/products/login.jpg" alt="Shopping Girl" />
        </div>

        <h3 class="login-title" style="color:brown">Login to Your Account</h3>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger py-2 small rounded text-center mb-3">
                @ViewBag.Error
            </div>
        }

        <form asp-action="Login" method="post">
            @Html.AntiForgeryToken()

            <input type="email" name="email" class="form-control-custom" placeholder="Enter Email" required />
            <input type="password" name="password" class="form-control-custom" placeholder="Enter Password" required />

            <div class="login-agreement">
                <input type="checkbox" id="agreeCheckbox" required />
                <label for="agreeCheckbox">I agree to the <a href="#">Terms</a> & <a href="#">Privacy Policy</a></label>
            </div>

            <button type="submit" class="btn-login" style="background-color:brown">Log In</button>
        </form>

        <div class="login-footer">
            <div class="login-footer-links">
                <a asp-action="ForgotPassword">Forgot your password?</a>
            </div>
            <div class="login-footer-links">
                Don't have an account? <a asp-action="Register">Create one</a>
            </div>
        </div>
    </div>
</div>