@{
    ViewData["Title"] = "Reset Password";
}

<div class="container d-flex justify-content-center align-items-center" style="min-height: 80vh;">
    <div class="card shadow-lg border-0" style="width: 400px; border-radius: 20px;">
        <div class="card-header bg-dark text-white text-center py-4" style="border-radius: 20px 20px 0 0;">
            <h4 class="mb-0"><i class="fas fa-user-shield me-2"></i>Account Recovery</h4>
            <small class="text-light-50">ClothNova Security Portal</small>
        </div>

        <div class="card-body p-4">
            <div id="step1">
                <p class="text-muted small">Enter your registered email to receive a 6-digit verification code.</p>
                <div class="form-group mb-3">
                    <label class="fw-bold small">Email Address</label>
                    <input type="email" id="email" class="form-control" placeholder="example@gmail.com" />
                </div>
                <button type="button" onclick="sendOTP()" id="btnSend" class="btn btn-dark w-100 py-2">
                    Send Verification Code
                </button>
            </div>

            <div id="step2" style="display:none;">
                <div class="alert alert-success small mb-3">
                    <i class="fas fa-check-circle me-1"></i> Code sent to your inbox!
                </div>

                <div class="form-group mb-3">
                    <label class="fw-bold small">Enter 6-Digit OTP</label>
                    <input type="text" id="otp" class="form-control text-center fw-bold" placeholder="000000" maxlength="6" />
                </div>

                <div class="form-group mb-3">
                    <label class="fw-bold small">New Password</label>
                    <input type="password" id="newPass" class="form-control" placeholder="Create strong password" />
                </div>

                <button type="button" onclick="resetPassword()" id="btnReset" class="btn btn-primary w-100 py-2">
                    Update Password
                </button>
            </div>
        </div>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />

<script>
    // 1. Send OTP Function
    function sendOTP() {
        var emailVal = $("#email").val();
        if (!emailVal) {
            Swal.fire('Error', 'Please enter your email first!', 'error');
            return;
        }

        $("#btnSend").prop('disabled', true).html('<i class="fas fa-spinner fa-spin"></i> Sending...');

        $.post("/Account/SendOTP", { email: emailVal }, function (res) {
            if (res.success) {
                $("#step1").fadeOut(300, function() {
                    $("#step2").fadeIn();
                });
            } else {
                Swal.fire('Failed', res.message, 'error');
                $("#btnSend").prop('disabled', false).text('Send Verification Code');
            }
        });
    }

    // 2. Reset Password Function
    function resetPassword() {
        var data = {
            email: $("#email").val(),
            otp: $("#otp").val(),
            newPassword: $("#newPass").val()
        };

        if (data.otp.length < 6 || data.newPassword.length < 6) {
            Swal.fire('Warning', 'Please fill all fields correctly (Min 6 chars)', 'warning');
            return;
        }

        $("#btnReset").prop('disabled', true).html('<i class="fas fa-spinner fa-spin"></i> Updating...');

        $.post("/Account/UpdatePassword", data, function (res) {
            if (res.success) {
                Swal.fire({
                    title: 'Success!',
                    text: 'Your password has been changed successfully.',
                    icon: 'success',
                    confirmButtonText: 'Go to Login'
                }).then(() => {
                    window.location.href = "/Account/Login";
                });
            } else {
                Swal.fire('Error', res.message, 'error');
                $("#btnReset").prop('disabled', false).text('Update Password');
            }
        });
    }
</script>