        margin-left: 5px;
    }

    .slider-btn {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        width: 50px;
        height: 50px;
        background: brown;
        border: 3px solid #fff;
        border-radius: 50%;
        box-shadow: 0 4px 20px rgba(0,0,0,0.4);
        cursor: pointer;
        font-size: 20px;
        color: #fff;
        z-index: 9999;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.3s ease;
        pointer-events: auto;
    }

        .slider-btn:hover {
            background: #e74c3c;
            transform: translateY(-50%) scale(1.15);
        }

        .slider-btn.prev {
            left: 5px;
        }

        .slider-btn.next {
