<section class="review-section">
    <div class="container">
        <h2 class="review-header">Customer Reviews</h2>

        <!-- Stats Row -->
        <div class="row review-stats-box">
            <!-- Left: Big Rating -->
            <div class="col-md-3 text-center border-end">
                <div class="big-rating" id="avgRating">5.0</div>
                <div class="stars">
                    <i class="fa fa-star"></i>
                    <i class="fa fa-star"></i>
                    <i class="fa fa-star"></i>
                    <i class="fa fa-star"></i>
                    <i class="fa fa-star"></i>
                </div>
                <div class="review-count" id="totalReviews">81 reviews</div>
            </div>

            <!-- Middle: Progress Bars -->
            <div class="col-md-5 px-4">
                <div class="rating-bar">
                    <span class="rating-label">5 Star</span>
                    <div class="rating-progress">
                        <div class="rating-fill" style="width: 97%; background: #ffa500;"></div>
                    </div>
                    <span class="rating-number" id="count5">79</span>
                </div>
                <div class="rating-bar">
                    <span class="rating-label">4 Star</span>
                    <div class="rating-progress">
                        <div class="rating-fill" style="width: 3%; background: #ddd;"></div>
                    </div>
                    <span class="rating-number" id="count4">2</span>
                </div>
                <div class="rating-bar">
                    <span class="rating-label">3 Star</span>
                    <div class="rating-progress">
                        <div class="rating-fill" style="width: 0%; background: #ddd;"></div>
                    </div>
                    <span class="rating-number" id="count3">0</span>
                </div>
                <div class="rating-bar">
                    <span class="rating-label">2 Star</span>
                    <div class="rating-progress">
                        <div class="rating-fill" style="width: 0%; background: #ddd;"></div>
                    </div>
                    <span class="rating-number" id="count2">0</span>
                </div>
                <div class="rating-bar">
                    <span class="rating-label">1 Star</span>
                    <div class="rating-progress">
                        <div class="rating-fill" style="width: 0%; background: #ddd;"></div>
                    </div>
                    <span class="rating-number" id="count1">0</span>
                </div>
            </div>

            <!-- Right: Photos & Button -->
            <div class="col-md-4">
                <div class="review-right-section">
                    <div class="review-photos" id="reviewPhotos">
                        @if (reviewImages != null && reviewImages.Any())
                        {
                            @foreach (var img in reviewImages.Take(8))
                            {
                                <img src="@img" class="review-photo" onerror="this.style.display='none'">
                            }
                        }
                        else
                        {
                            @for (int i = 1; i <= 8; i++)
                            {
                                <div class="review-photo" style="background: #f0f0f0; display: flex; align-items: center; justify-content: center; color: #999; font-size: 10px;">
                                    <i class="fa fa-image"></i>
                                </div>
                            }
                        }
                    </div>
                    <button type="button" class="btn-write-review" onclick="openReviewModal()">
                        <i class="fa fa-pen me-2"></i>Write a store review
                    </button>
                </div>
            </div>
        </div>

        <!-- Tabs -->
        <div class="review-tabs">
            <span class="review-tab active" onclick="switchTab('reviews')">Reviews (<span id="tabCount">81</span>)</span>
            <span class="review-tab" onclick="switchTab('store')">Store reviews (0)</span>
        </div>

        <!-- Reviews List - DYNAMIC -->
        <div class="reviews-list" id="reviewsList">
            @if (reviews != null && reviews.Any())
            {
                @foreach (var review in reviews)
                {
                    var initials = string.Join("", review.CustomerName.Split(' ').Take(2).Select(n => n[0]));

                    <div class="review-item" data-id="@review.Id">
                        <div class="reviewer-avatar">
                            @initials
                            <i class="fa fa-check-circle verified-icon"></i>
                        </div>
                        <div class="review-content">
                            <div class="d-flex justify-content-between">
                                <div>
                                    <div class="reviewer-name">@review.CustomerName</div>
                                    <div class="verified-badge">
                                        <i class="fa fa-check-circle me-1"></i>Verified purchase
                                    </div>
                                </div>
                                <span class="review-date">@review.CreatedAt?.ToString("dd/MM/yyyy")</span>
                            </div>
                            <div class="review-stars">
                                @for (int i = 0; i < review.Rating; i++)
                                {
                                    <i class="fa fa-star"></i>
                                }
                            </div>
                            <div class="review-text">@review.Message</div>
                            @if (!string.IsNullOrEmpty(review.ImageUrl))
                            {
                                <img src="@review.ImageUrl" style="max-width: 80px; border-radius: 6px; margin-top: 10px;">
                            }
                        </div>
                    </div>
                }
            }
            else
            {
                <!-- Default review show hoga -->
                <div class="review-item">
                    <div class="reviewer-avatar">SS</div>
                    <div class="review-content">
                        <div class="d-flex justify-content-between">
                            <div>
                                <div class="reviewer-name">Sana S.</div>
                                <div class="verified-badge">
                                    <i class="fa fa-check-circle me-1"></i>Verified purchase
                                </div>
                            </div>
                            <span class="review-date">04/06/2026</span>
                        </div>
                        <div class="review-stars">
                            <i class="fa fa-star"></i><i class="fa fa-star"></i><i class="fa fa-star"></i><i class="fa fa-star"></i><i class="fa fa-star"></i>
                        </div>
                        <div class="review-text">Pretty gud...</div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<!-- FIXED MODAL - Scrollable & Compact -->
<div id="reviewModal" class="review-modal">
    <div class="modal-overlay" onclick="closeReviewModal()"></div>
    <div class="modal-container">
        <div class="modal-header-custom">
            <h5 class="modal-title"><i class="fa fa-star text-warning me-2"></i>Write a Review</h5>
            <button type="button" class="btn-close-custom" onclick="closeReviewModal()">&times;</button>
        </div>
        <div class="modal-body-custom">
            <form id="reviewForm" enctype="multipart/form-data">
                <!-- Star Rating -->
                <div class="star-input">
                    <input type="radio" name="Rating" value="5" id="star5" required>
                    <label for="star5"><i class="fa fa-star"></i></label>
                    <input type="radio" name="Rating" value="4" id="star4">
                    <label for="star4"><i class="fa fa-star"></i></label>
                    <input type="radio" name="Rating" value="3" id="star3">
                    <label for="star3"><i class="fa fa-star"></i></label>
                    <input type="radio" name="Rating" value="2" id="star2">
                    <label for="star2"><i class="fa fa-star"></i></label>
                    <input type="radio" name="Rating" value="1" id="star1">
                    <label for="star1"><i class="fa fa-star"></i></label>
                </div>

                <input type="text" name="CustomerName" id="revName" class="form-input" placeholder="Your Name *" required>
                <input type="email" name="Email" id="revEmail" class="form-input" placeholder="Your Email *" required>
                <textarea name="Message" id="revMessage" class="form-input" rows="3" placeholder="Your review *" required></textarea>

                <!-- FIXED: Compact Upload -->
                <div class="upload-box" id="uploadBox" onclick="document.getElementById('revFile').click()">
                    <div id="uploadContent">
                        <i class="fa fa-camera" style="font-size: 24px; color: #999;"></i>
                        <p style="color: #666; margin: 5px 0 0; font-size: 13px;">Click to upload photo</p>
                    </div>
                    <div class="upload-preview" id="uploadPreview" style="display: none;">
                        <img id="imgPreview">
                        <span style="color: #666; font-size: 13px; cursor: pointer;" onclick="removeImage(event)">
                            <i class="fa fa-trash text-danger"></i> Remove
                        </span>
                    </div>
                    <input type="file" name="imageFile" id="revFile" accept="image/*" style="display:none" onchange="previewImage(this)">
                </div>

                <button type="submit" id="revSubmit" class="submit-btn" disabled>
                    <i class="fa fa-paper-plane me-2"></i>Send Review
                </button>
            </form>
        </div>
    </div>
</div>

