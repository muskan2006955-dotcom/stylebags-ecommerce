        (function() {
            const track = document.getElementById('sliderTrack');
            let currentSlide = 0;
            let autoSlideInterval;

            const config = {
                gap: 15,
                autoplayDelay: 3000,
                slidesToScroll: 5, // 5 cards ek baar mein
                transitionDuration: 500
            };

            function getVisibleCards() {
                const width = window.innerWidth;
                if (width < 576) return 2;
                if (width < 768) return 2;
                if (width < 992) return 3;
                if (width < 1200) return 4;
                return 5;
            }

            function getTotalCards() {
                return track?.children?.length || 0;
            }

            function getCardWidth() {
                if (!track || !track.children[0]) return 0;
                const card = track.children[0];
                return card.offsetWidth + config.gap;
            }

            function getMaxSlide() {
                const total = getTotalCards();
                const visible = getVisibleCards();

                if (total <= visible) return 0;

                // FIXED: Kitni slides possible hain
                return total - visible;
            }

            function updateSlider() {
                const maxSlide = getMaxSlide();
                const visible = getVisibleCards();

                // FIXED: Loop slider
                if (currentSlide < 0) {
                    currentSlide = maxSlide;
                }
                if (currentSlide > maxSlide) {
                    currentSlide = 0;
                }

                const cardWidth = getCardWidth();
                if (cardWidth > 0) {
                    track.style.transform = `translateX(-${currentSlide * cardWidth}px)`;
                }

                updateButtonStates(maxSlide);
            }

            function updateButtonStates(maxSlide) {
                const prevBtn = document.querySelector('.slider-btn.prev');
                const nextBtn = document.querySelector('.slider-btn.next');

                if (prevBtn && nextBtn) {
                    const hasMore = getTotalCards() > getVisibleCards();
                    prevBtn.style.opacity = hasMore ? '1' : '0.3';
                    nextBtn.style.opacity = hasMore ? '1' : '0.3';
                    prevBtn.style.pointerEvents = hasMore ? 'auto' : 'none';
                    nextBtn.style.pointerEvents = hasMore ? 'auto' : 'none';
                }
            }

            window.moveSlide = function(direction) {
                console.log('Move slide:', direction, 'Current:', currentSlide);

                const visible = getVisibleCards();
                // FIXED: 5 cards move karo har baar
                currentSlide += (direction * visible);
                updateSlider();
            };

            function startAutoSlide() {
                stopAutoSlide();
                if (getTotalCards() > getVisibleCards()) {
                    autoSlideInterval = setInterval(() => window.moveSlide(1), config.autoplayDelay);
                }
            }

            function stopAutoSlide() {
                if (autoSlideInterval) {
                    clearInterval(autoSlideInterval);
                    autoSlideInterval = null;
                }
            }

            let resizeTimeout;
            window.addEventListener('resize', function() {
                clearTimeout(resizeTimeout);
                resizeTimeout = setTimeout(function() {
                    currentSlide = 0;
                    updateSlider();
                }, 250);
            });

            const outer = document.querySelector('.slider-outer');
            if (outer) {
                outer.addEventListener('mouseenter', stopAutoSlide);
                outer.addEventListener('mouseleave', startAutoSlide);
            }

            function init() {
                if (track && track.children.length > 0) {
                    updateSlider();
                    startAutoSlide();
                    console.log('Slider ready - Total cards:', track.children.length, 'Visible:', getVisibleCards());
                } else {
                    setTimeout(init, 100);
                }
            }

            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', init);
            } else {
                init();
            }

            window.addEventListener('load', init);
        })();
    </script>




<script>
        // ===== MODAL FUNCTIONS =====
        function openReviewModal() {
            document.getElementById('reviewModal').classList.add('show');
            document.body.style.overflow = 'hidden';
        }

        function closeReviewModal() {
            document.getElementById('reviewModal').classList.remove('show');
            document.body.style.overflow = '';
            resetForm();
        }

        function resetForm() {
            document.getElementById('reviewForm').reset();
            document.getElementById('uploadContent').style.display = 'block';
            document.getElementById('uploadPreview').style.display = 'none';
            document.getElementById('imgPreview').src = '';
            document.getElementById('revSubmit').disabled = true;
            document.getElementById('revSubmit').classList.remove('active');
        }

        // ===== IMAGE HANDLING =====
        function previewImage(input) {
            if (input.files && input.files[0]) {
                var reader = new FileReader();
                reader.onload = function(e) {
                    document.getElementById('uploadContent').style.display = 'none';
                    document.getElementById('uploadPreview').style.display = 'flex';
                    document.getElementById('imgPreview').src = e.target.result;
                }
                reader.readAsDataURL(input.files[0]);
            }
        }

        function removeImage(e) {
            e.stopPropagation();
            document.getElementById('revFile').value = '';
            document.getElementById('uploadContent').style.display = 'block';
            document.getElementById('uploadPreview').style.display = 'none';
            document.getElementById('imgPreview').src = '';
        }

        // ===== FORM VALIDATION =====
        const form = document.getElementById('reviewForm');
        const submitBtn = document.getElementById('revSubmit');

        function validateForm() {
            const rating = document.querySelector('input[name="Rating"]:checked');
            const name = document.getElementById('revName').value.trim();
            const email = document.getElementById('revEmail').value.trim();
            const message = document.getElementById('revMessage').value.trim();
            const emailValid = /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/.test(email);

            if (rating && name.length >= 2 && emailValid && message.length >= 5) {
                submitBtn.disabled = false;
                submitBtn.classList.add('active');
            } else {
                submitBtn.disabled = true;
                submitBtn.classList.remove('active');
            }
        }

        form.addEventListener('input', validateForm);
        form.addEventListener('change', validateForm);

        // ===== FORM SUBMIT - DYNAMIC =====
        form.addEventListener('submit', function(e) {
            e.preventDefault();

            submitBtn.innerHTML = '<i class="fa fa-spinner fa-spin me-2"></i>Sending...';
            submitBtn.disabled = true;

            var formData = new FormData(this);

            fetch('/Home/CreateReview', {
                method: 'POST',
                body: formData
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    // Add new review to list dynamically
                    addReviewToList({
                        customerName: document.getElementById('revName').value,
                        rating: document.querySelector('input[name="Rating"]:checked').value,
                        message: document.getElementById('revMessage').value,
                        imageUrl: document.getElementById('imgPreview').src.startsWith('data:') ? null : document.getElementById('imgPreview').src,
                        createdAt: new Date().toISOString()
                    });

                    alert(data.message);
                    closeReviewModal();
                } else {
                    alert(data.message);
                    submitBtn.innerHTML = '<i class="fa fa-paper-plane me-2"></i>Send Review';
                    submitBtn.disabled = false;
                    submitBtn.classList.add('active');
                }
            })
            .catch(error => {
                console.error('Error:', error);
                alert('Something went wrong!');
                submitBtn.innerHTML = '<i class="fa fa-paper-plane me-2"></i>Send Review';
                submitBtn.disabled = false;
            });
        });

        // ===== ADD REVIEW DYNAMICALLY =====
        function addReviewToList(review) {
            var initials = review.customerName.split(' ').map(n => n[0]).join('').substring(0, 2);
            var stars = '';
            for (var i = 0; i < parseInt(review.rating); i++) {
                stars += '<i class="fa fa-star"></i>';
            }

            var imageHtml = review.imageUrl ? `<img src="${review.imageUrl}" style="max-width: 80px; border-radius: 6px; margin-top: 10px;">` : '';

            var html = `
                <div class="review-item" style="animation: fadeIn 0.5s;">
                    <div class="reviewer-avatar">
                        ${initials}
                        <i class="fa fa-check-circle verified-icon"></i>
                    </div>
                    <div class="review-content">
                        <div class="d-flex justify-content-between">
                            <div>
                                <div class="reviewer-name">${review.customerName}</div>
                                <div class="verified-badge">
                                    <i class="fa fa-check-circle me-1"></i>Verified purchase
                                </div>
                            </div>
                            <span class="review-date">Just now</span>
                        </div>
                        <div class="review-stars">${stars}</div>
                        <div class="review-text">${review.message}</div>
                        ${imageHtml}
                    </div>
                </div>
            `;

            // Add to top of list
            var list = document.getElementById('reviewsList');
            list.insertAdjacentHTML('afterbegin', html);

            // Update count
            var count = parseInt(document.getElementById('tabCount').innerText) + 1;
            document.getElementById('tabCount').innerText = count;
            document.getElementById('totalReviews').innerText = count + ' reviews';
        }

        // ===== TAB SWITCH =====
        function switchTab(tab) {
            document.querySelectorAll('.review-tab').forEach(t => t.classList.remove('active'));
            event.target.classList.add('active');
        }

        // Close on Escape
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') closeReviewModal();
        });

        // Add animation style
        var style = document.createElement('style');
        style.innerHTML = `
            @@keyframes fadeIn {
                from { opacity: 0; transform: translateY(-20px); }
                to { opacity: 1; transform: translateY(0); }
            }
        `;
        document.head.appendChild(style);
    </script>


    <script>
        $(document).ready(function() {
            // Theme ke set-bg ko disable karein categories ke liye
            $('.categories__item').each(function() {
                var bg = $(this).attr('data-setbg');
                if (bg) {
                    $(this).css('background-image', 'url(' + bg + ')');
                }
            });
        });


        // ===== BEST SELLING LOAD MORE =====
        // ===== BEST SELLING LOAD MORE =====
               // ===== BEST SELLING LOAD MORE =====
        function loadMoreBestSelling() {
            var hiddenItems = document.querySelectorAll('.extra-best-item.d-none');
            var btn = document.getElementById('loadMoreBest');
            var btnText = btn.querySelector('.btn-text');
            var btnLoader = document.getElementById('btnLoaderBest');

            // Loading state
            btnText.textContent = "Loading...";
            btnLoader.style.display = "inline-block";
            btn.style.pointerEvents = "none";

            // 8 items show karein
            var shown = 0;
            hiddenItems.forEach(function(item) {
                if (shown < 8) {
                    item.classList.remove('d-none');
                    item.style.animation = "fadeInUp 0.5s ease";
                    shown++;
                }
            });

            // Reset button
            setTimeout(function() {
                btnText.textContent = "Load More Best Sellers";
                btnLoader.style.display = "none";
                btn.style.pointerEvents = "auto";

                // Agar sab show ho gaye toh button hide
                if (document.querySelectorAll('.extra-best-item.d-none').length === 0) {
                    btn.parentElement.style.display = "none";
                }
            }, 600);
        }  // ✅ YEH BRACKET ZAROORI HAI - CHECK KAREIN KOI EXTRA NA HO
    </script>


    
