@{
    var bestProducts = ViewBag.BestSelling as List<BagsWebsite.Models.Product>;
    var categoryName = ViewBag.BestCategoryName as string;
    var categoryId = (bestProducts?.FirstOrDefault()?.CategoryId) ?? 0;
}



<section class="best-selling-section">
    <div class="container-fluid">
        <div class="best-selling-header">
            <h2>@categoryName Collection</h2>
            <p>Our most loved styles trending now</p>
        </div>

        <button type="button" class="slider-btn prev" onclick="moveSlide(-1)">
            <i class="fa fa-chevron-left"></i>
        </button>
        
        <button type="button" class="slider-btn next" onclick="moveSlide(1)">
            <i class="fa fa-chevron-right"></i>
        </button>

        <div class="slider-outer">
            <div class="slider-wrapper">
                <div class="slider-track" id="sliderTrack">
                    @if (bestProducts != null && bestProducts.Any())
                    {
                        // FIXED: .Take(5) HATA DIYA! Ab saare products ayenge
                        @foreach (var product in bestProducts)
                        {
                            var image = product.ProductImages?.FirstOrDefault()?.ImageUrl ?? "/uploads/products/no-image.jpg";
                            var price = product.Price;
                            var discount = product.Discount ?? 0;
                            var finalPrice = price * (1 - discount / 100m);
                            
                            <a href="@Url.Action("Index", "Products", new { categoryId = product.CategoryId })" class="slide-card">
                                <div style="position: relative;">
                                    <img src="@image" alt="@product.Name" class="slide-image" loading="lazy">
                                    @if (discount > 0)
                                    {
                                        <span class="slide-badge">-@discount%</span>
                                    }
                                </div>
                                <div class="slide-content">
                                    <h3 class="slide-title">@product.Name</h3>
                                    <div>
                                        <span class="slide-price">$@finalPrice.ToString("0")</span>
                                        @if (discount > 0)
                                        {
                                            <span class="slide-old-price">$@price.ToString("0")</span>
                                        }
                                    </div>
                                </div>
                            </a>
                        }
                    }
                    else
                    {
                        // FIXED: Dummy bhi 10 bana diye
                        @for (int i = 1; i <= 10; i++)
                        {
                            <a href="@Url.Action("Index", "Products", new { categoryId = categoryId })" class="slide-card">
                                <div style="position: relative;">
                                    <img src="@string.Format("/uploads/products/bag-{0}.jpg", ((i-1) % 5) + 1)" 
                                         alt="@string.Format("Bag {0}", i)" 
                                         class="slide-image" 
                                         loading="lazy"
                                         onerror="this.src='/uploads/products/no-image.jpg'">
                                    <span class="slide-badge">HOT</span>
                                </div>
                                <div class="slide-content">
                                    <h3 class="slide-title">Premium @(categoryName) @i</h3>
                                    <div>
                                        <span class="slide-price">$@(99 + (i % 5) * 15)</span>
                                        <span class="slide-old-price">$@(129 + (i % 5) * 15)</span>
                                    </div>
                                </div>
                            </a>
                        }
                    }
                </div>
            </div>
        </div>
    </div>
</section>











<!-- Product Section Begin -->

<section class="product spad">

    <div class="container">



        <div class="row">
            <div class="col-lg-12 text-center">
                <div class="section-title">
                    <h2 style="font-weight: 700; color:brown; margin-bottom: 15px;">Our Signature Collection</h2>
                    <p style="color: #666; max-width: 600px; margin: 0 auto 45px;">
                        Explore our curated selection of premium products, designed with quality and style in mind to elevate your everyday lifestyle.
                    </p>
                </div>
            </div>
        </div>

        <div class="row property__gallery">

            @if (Model != null && Model.Count() > 0)

            {

                @foreach (var item in Model)

                {

                    @* Category-based classes added here for filtering (e.g., mix handbag) *@

                    <div class="col-lg-3 col-md-4 col-6 mix @(item.Category?.Name?.ToLower() ?? "handbag")">

                        <div class="product-wrapper mb-4">

                            <div class="enshee-card-img-box">

                                <a asp-controller="Products" asp-action="Details" asp-route-id="@item.Id">

                                    <img class="main-img" src="@(item.ProductImages.FirstOrDefault()?.ImageUrl ?? "/img/no-image.jpg")">

                                    <img class="hover-img" src="@(item.ProductImages.Skip(1).FirstOrDefault()?.ImageUrl ?? item.ProductImages.FirstOrDefault()?.ImageUrl)">

                                    <div class="card-overlay"></div>

                                </a>





                                <a href="javascript:void(0)" class="static-heart" onclick="addToWishlist('@item.Id', this)" data-product-id="@item.Id">

                                    <i class="fa-regular fa-heart"></i>

                                </a>



                                @if (item.Discount > 0)

                                {

                                    <div class="status-badge bg-danger">

                                        <span>-@item.Discount%</span>

                                    </div>

                                }

                                else

                                {

                                    <div class="status-badge bg-danger text-white">

                                        <span>HOT</span>

                                    </div>

                                }



                                <div class="hover-actions-vertical">

                                    <a href="javascript:void(0)" class="oval-btn quick-view-btn" data-id="@item.Id">

                                        <span class="btn-text">Quick View</span>

                                        <i class="fa fa-eye btn-icon"></i>

                                    </a>

                                    <a href="javascript:void(0)"
                                       onclick="addToCart(@item.Id, 1); return false;"
                                       class="oval-btn add-to-cart">
                                        <span class="btn-text">Add to Cart</span>
                                        <i class="fa fa-shopping-cart btn-icon"></i>
                                    </a>

                                </div>

                            </div>



                            <div class="product-info-footer d-flex justify-content-between align-items-end mt-2 px-1">

                                <div class="product-price-section">

                                    <h6 class="mb-0 fw-bold" style="font-size: 14px;">@item.Name</h6>

                                    @if (item.Discount > 0)

                                    {

                                        <span class="text-muted text-decoration-line-through" style="font-size: 11px;">

                                            Rs. @item.Price.ToString("N0")

                                        </span>

                                        <span class="ms-1 fw-bold text-danger" style="font-size: 13px;">

                                            @{

                                                decimal finalAmount = (decimal)item.Price * (1 - ((decimal)item.Discount / 100));

                                            }

                                            Rs. @finalAmount.ToString("N0")

                                        </span>

                                    }

                                    else

                                    {

                                        <span class="fw-bold text-dark" style="font-size: 13px;">Rs. @item.Price.ToString("N0")</span>

                                    }

                                </div>



                                <div class="color-palette-outer">

                                    <div class="d-flex gap-1">

                                        @foreach (var colorGroup in item.ProductImages.Where(x => !string.IsNullOrEmpty(x.ColorCode)).GroupBy(x => x.ColorCode).Take(3))

                                        {

                                            <div class="color-seed"
                                                 style="background: @colorGroup.Key; width:12px; height:12px; border-radius:50%; border: 1px solid #ddd;"
                                                 onclick="changeColorDirect(this, '@colorGroup.First().ImageUrl')">
                                            </div>

                                        }

                                    </div>

                                </div>

                            </div>

                        </div>

                    </div>

                }

            }

            else

            {

                <div class="col-12 text-center py-5">

                    <h4 class="text-muted">Currently No Bags Available</h4>

                </div>



            }
            <div class="col-lg-12 text-center mt-5">
                <a href="javascript:void(0)" id="loadMore" class="load-more-btn" style="display: none;">
                    <span class="btn-text">Load More Products</span>
                    <div class="spinner-loader" id="btnLoader" style="display: none;"></div>
                </a>
            </div>


    <div class="modal fade" id="quickViewModal" tabindex="-1">

        <div class="modal-dialog modal-lg modal-dialog-centered">

            <div class="modal-content border-0 rounded-0 p-3">

                <div class="text-end">
                </div>



                <div class="modal-body pt-0" id="quickViewContent">
                </div>

            </div>

        </div>

    </div>
   

</section><!-- Banner Section Begin -->
