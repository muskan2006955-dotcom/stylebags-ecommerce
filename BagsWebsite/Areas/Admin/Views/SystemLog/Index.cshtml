@model IEnumerable<BagsWebsite.Models.LoginLog>
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers


@{
    ViewData["Title"] = "Security Analytics";
    Layout = "_AdminLayout";
}

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<style>
    .glass-card {
        border-radius: 12px;
        background: #ffffff;
        box-shadow: 0 4px 15px rgba(0,0,0,0.05);
        border: 1px solid #f1f5f9;
    }

    .status-success {
        background: #dcfce7;
        color: #15803d;
        padding: 4px 10px;
        border-radius: 20px;
        font-size: 11px;
        font-weight: bold;
    }

    .status-failed {
        background: #fee2e2;
        color: #b91c1c;
        padding: 4px 10px;
        border-radius: 20px;
        font-size: 11px;
        font-weight: bold;
    }

    .browser-text {
        font-size: 11px;
        color: #94a3b8;
        max-width: 200px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }
</style>

<div class="container-fluid px-4 mt-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold text-dark mb-0">System Activity Logs</h3>
            <p class="text-muted mb-0">Security monitoring and login history analysis.</p>
        </div>
        <div class="d-flex gap-2">
            <button onclick="window.location.reload()" class="btn btn-outline-primary px-3 shadow-sm">
                <i class="fa fa-sync-alt"></i>
            </button>
            <form id="deleteLogsForm" asp-action="ClearAllLogs" asp-area="Admin" asp-controller="SystemLog" method="post">
                @Html.AntiForgeryToken()
                <button type="button" class="btn btn-danger px-4" onclick="confirmDelete()">
                    <i class="fa fa-trash-alt me-2"></i>Delete All History
                </button>
            </form>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm" role="alert">
            <i class="fa fa-check-circle me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="glass-card p-4 mb-4">
        <h6 class="fw-bold mb-4 text-muted small text-uppercase">Login Trends (Last 7 Days)</h6>
        <canvas id="loginChart" style="max-height: 250px;"></canvas>
    </div>

    <div class="glass-card overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr class="text-muted small">
                        <th class="ps-4">DATE & TIME</th>
                        <th>USER EMAIL</th>
                        <th>IP ADDRESS</th>
                        <th>STATUS</th>
                        <th>BROWSER</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr><td colspan="5" class="text-center py-5 text-muted">No activity recorded.</td></tr>
                    }
                    @foreach (var log in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <span class="d-block text-dark fw-medium" style="font-size:13px;">@log.LoginTime?.ToString("MMM dd, yyyy")</span>
                                <span class="text-muted small">@log.LoginTime?.ToString("hh:mm tt")</span>
                            </td>
                            <td class="fw-bold text-secondary">@log.UserEmail</td>
                            <td class="text-muted small">@log.IpAddress</td>
                            <td>
                                <span class="@(log.Status == "Success" ? "status-success" : "status-failed")">
                                    @log.Status
                                </span>
                            </td>
                            <td><div class="browser-text" title="@log.Browser">@log.Browser</div></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="confirmClear" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-body p-4 text-center">
                <i class="fa fa-exclamation-triangle text-danger fs-1 mb-3"></i>
                <h4 class="fw-bold">Clear All Logs?</h4>
                <p class="text-muted">This action will permanently delete all login history. You cannot undo this.</p>
                <div class="d-flex gap-2 justify-content-center mt-4">
                    <button type="button" class="btn btn-light px-4" data-bs-dismiss="modal">Cancel</button>
                    <form asp-action="ClearAllLogs" method="post">
                        <button type="submit" class="btn btn-danger px-4">Yes, Delete All</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
<script>
    function confirmDelete() {
        Swal.fire({
            title: 'Are you sure?',
            text: "You won't be able to revert this! All login history will be wiped out.",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#d33', // Red color for delete
            cancelButtonColor: '#6c757d', // Gray color for cancel
            confirmButtonText: 'Yes, delete everything!',
            cancelButtonText: 'No, keep it'
        }).then((result) => {
            if (result.isConfirmed) {
                // Agar user 'Yes' click kare to form submit kar do
                document.getElementById('deleteLogsForm').submit();
            }
        })
    }
</script>
<script>
    const ctx = document.getElementById('loginChart').getContext('2d');
    new Chart(ctx, {
        type: 'line',
        data: {
            labels: @Html.Raw(Json.Serialize(ViewBag.ChartLabels)),
            datasets: [
                {
                    label: 'Success',
                    data: @Html.Raw(Json.Serialize(ViewBag.SuccessData)),
                    borderColor: '#10b981',
                    backgroundColor: 'rgba(16, 185, 129, 0.05)',
                    fill: true, tension: 0.4
                },
                {
                    label: 'Failed',
                    data: @Html.Raw(Json.Serialize(ViewBag.FailedData)),
                    borderColor: '#ef4444',
                    backgroundColor: 'rgba(239, 68, 68, 0.05)',
                    fill: true, tension: 0.4
                }
            ]
        },
        options: {
            responsive: true,
            scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } }
        }
    });
</script>