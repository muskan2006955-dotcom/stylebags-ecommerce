@model BagsWebsite.Models.Category
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Category Details";
}

<style>
    .glass-card {
        border-radius: 12px;
        background: #ffffff;
        box-shadow: 0 4px 15px rgba(0,0,0,0.05);
        border: 1px solid #f1f5f9;
        overflow: hidden;
        margin-top: 20px;
    }

    .details-header-area {
        background: #f8fafc;
        border-bottom: 1px solid #e2e8f0;
        padding: 25px;
    }

    .category-title {
        font-weight: 600;
        color: #1e293b;
        margin-bottom: 5px;
    }

    .desc-box {
        background: #ffffff;
        border: 1px dashed #cbd5e1;
        padding: 15px;
        border-radius: 8px;
        color: #64748b;
        font-size: 0.95rem;
        line-height: 1.5;
    }

    /* Product Table Styling */
    .table thead th {
        background-color: #ffffff;
        color: #64748b;
        font-weight: 700;
        text-transform: uppercase;
        font-size: 11px;
        padding: 15px;
        border-bottom: 2px solid #f1f5f9;
    }

    .product-row:hover {
        background-color: #f8fafc;
    }

    .price-badge {
        background: #dcfce7;
        color: #15803d;
        padding: 4px 10px;
        border-radius: 6px;
        font-size: 12px;
        font-weight: 600;
    }

    .btn-action-custom {
        font-size: 13px;
        font-weight: 500;
        padding: 8px 20px;
        border-radius: 8px;
        transition: 0.2s;
    }
</style>

<div class="container-fluid px-4 mt-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold text-dark mb-0">Category View</h3>
            <p class="text-muted mb-0">Detailed information and associated products</p>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="Index" class="btn btn-outline-secondary btn-action-custom">
                <i class="fa fa-arrow-left me-2"></i>Back to List
            </a>
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary btn-action-custom">
                <i class="fa fa-edit me-2"></i>Edit Category
            </a>
        </div>
    </div>

    <div class="glass-card">
        <div class="details-header-area">
            <div class="row align-items-center">
                <div class="col-md-6">
                    <span class="text-muted small fw-bold text-uppercase tracking-wider">Category Name</span>
                    <h2 class="category-title">@Model.Name</h2>
                </div>
                <div class="col-md-6">
                    <span class="text-muted small fw-bold text-uppercase tracking-wider d-block mb-2">Banner Description</span>
                    <div class="desc-box">
                        @if (!string.IsNullOrEmpty(Model.Description))
                        {
                            @Model.Description
                        }
                        else
                        {
                            <span class="text-danger italic">No description set for this category.</span>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="p-4">
            <h5 class="fw-bold mb-4 text-dark"><i class="fa fa-boxes me-2 text-primary"></i>Products in this Category</h5>

            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th style="width: 10%;">ID</th>
                            <th style="width: 60%;">Product Name</th>
                            <th style="width: 30%;" class="text-end">Price</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Products != null && Model.Products.Any())
                        {
                            foreach (var p in Model.Products)
                            {
                                <tr class="product-row">
                                    <td class="text-muted">#@p.Id</td>
                                    <td class="fw-medium text-dark">@p.Name</td>
                                    <td class="text-end">
                                        <span class="price-badge">Rs. @p.Price.ToString("N0")</span>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="3" class="text-center py-5 text-muted">
                                    <i class="fa fa-info-circle d-block mb-2 fs-4"></i>
                                    No products found in this category.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="bg-light p-3 border-top px-4 text-end">
            <span class="text-muted me-3">Total Inventory Items:</span>
            <span class="fw-bold text-dark">@(Model.Products?.Count() ?? 0)</span>
        </div>
    </div>
</div>