@model BagsWebsite.Models.User
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Edit User";
}

<div class="container mt-4">
    <div class="card shadow-sm border-0 col-md-8 mx-auto">
        <div class="card-header text-white" style="background: #3e2723;">
            <h4 class="mb-0">Edit User: @Model.FirstName @Model.LastName</h4>
        </div>
        <div class="card-body p-4">
            <form asp-action="Edit" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="fw-bold">First Name</label>
                        <input asp-for="FirstName" class="form-control" />
                        <span asp-validation-for="FirstName" class="text-danger"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="fw-bold">Last Name</label>
                        <input asp-for="LastName" class="form-control" />
                        <span asp-validation-for="LastName" class="text-danger"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="fw-bold">Email Address</label>
                        <input asp-for="Email" class="form-control bg-light" readonly />
                        <small class="text-muted">Email cannot be modified.</small>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="fw-bold">Assign Role</label>
                        <select asp-for="RoleId" class="form-select" asp-items="ViewBag.RoleId">
                            <option value="">-- Select Role --</option>
                        </select>
                        <span asp-validation-for="RoleId" class="text-danger"></span>
                    </div>
                </div>

                <div class="d-flex gap-2 border-top pt-3 mt-3">
                    <button type="submit" class="btn btn-primary px-4" style="background: #b71c1c; border: none;">Save Changes</button>
                    <a asp-action="Index" class="btn btn-outline-secondary px-4">Back to List</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}